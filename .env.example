# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Database ---
# Points at the existing local Postgres 'prism-local-db' container (postgres:16) on host port 5434.
# The database 'daytrade' should already exist (created by scripts/init_db.py).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/daytrade
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5434/daytrade

# --- FastAPI ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_BASE=ws://localhost:8000

# --- DTD ingestion ---
# Path where Playwright stores the logged-in browser profile (relative to repo root).
DTD_PLAYWRIGHT_PROFILE_DIR=./playwright_profile
# WT member dashboard is the real entry point. Login flow:
#   1. https://www.warriortrading.com/dashboard/  -> click "Click here to Enter"
#   2. /chat-room-access/                          -> click "Click here to Enter the Platform"
#   3. chatroom.warriortrading.com/dashboard?...   -> Accept disclaimer
#   4. DTD chatroom loads (charts), and may pop a second window with the scanner widgets.
DTD_LOGIN_URL=https://www.warriortrading.com/dashboard/
DTD_API_HOST=scan-prod.warriortrading.com
# Widgets we observe. 5 Pillars uses a UUID widget id - put yours here once you grab it.
DTD_WIDGETS=Momo,Running_Up
DTD_FIVE_PILLARS_WIDGET=
# Run headed so the user can click through the gates each session. Cookies persist in
# the Playwright profile so SSO and disclaimer-acceptance are sticky.
DTD_HEADLESS=false

# --- Funnel config ---
# Per-symbol cooldown before a new Candidate is created for the same symbol.
CANDIDATE_COOLDOWN_MINUTES=10

# --- Default filter rules (seeded on first boot, can be edited from the UI) ---
DEFAULT_MIN_PRICE=1.50
DEFAULT_MAX_PRICE=20.00
DEFAULT_MAX_FLOAT=20000000
DEFAULT_MIN_REL_VOL_TODAY=3.0
DEFAULT_MIN_REL_VOL_5MIN=3.0
DEFAULT_MIN_REL_GAIN=5.0
DEFAULT_REQUIRE_NEWS_WITHIN_MINUTES=240

# --- IBKR ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
# Must NOT equal TWS Master API client ID (typically 101) - causes order-echo bugs.
IBKR_CLIENT_ID=37
IBKR_TRADING_MODE=paper
IBKR_MARKET_DATA_TYPE=delayed
LIVE_TRADING_ENABLED=false
PAPER_TRADING_ONLY=true
MANUAL_APPROVAL_REQUIRED=true
# Required for live trading on a login with multiple linked accounts. Leave
# blank for paper.
IBKR_TARGET_ACCOUNT=

# --- Risk guardrails (v1.5) ---
MAX_DAILY_LOSS_USD=200
MAX_OPEN_POSITIONS=2
MAX_TRADES_PER_DAY=10
MAX_ORDER_RATE_PER_MIN=4
MIN_SECONDS_BEFORE_OPEN=0
